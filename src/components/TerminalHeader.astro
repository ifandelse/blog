---
// Terminal-style headers like: $ ls ~/posts
import TypingText from './TypingText.astro';

interface Props {
  command: string;
  showCursor?: boolean;
  typewriter?: boolean;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const {
  command,
  showCursor = false,
  typewriter = false,
  size = 'lg',
  class: className = ''
} = Astro.props;

const typingSpeed = typewriter ? Math.max(20, Math.min(80, Math.round(1200 / command.length))) : 0;

const sizeClasses = {
  sm: 'text-lg',
  md: 'text-2xl',
  lg: 'text-3xl md:text-4xl',
  xl: 'text-4xl md:text-5xl'
};
---

<div class:list={["terminal-header", sizeClasses[size], className]}>
  <span class="terminal-prompt">$</span>
  {typewriter ? (
    <TypingText text={command} speed={typingSpeed} hideCursor={true} class="terminal-command" />
  ) : (
    <span class="terminal-command">{command}</span>
  )}
  {showCursor && <span class="terminal-cursor"></span>}
</div>

<style>
  .terminal-header {
    font-family: 'JetBrains Mono', 'Geist Mono', monospace;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
</style>
